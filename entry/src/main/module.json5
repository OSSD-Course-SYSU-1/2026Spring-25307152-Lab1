        ]
      },
      {
        "name": "SmartHomeCard",
        "displayName": "$string:SmartHomeCard",
        "description": "$string:SmartHomeCardDesc",
        "src": "./ets/widget/pages/SmartHomeCard.ets",
        "uiSyntax": "arkts",
        "window": {
          "designWidth": 720,
          "autoDesignWidth": true
        },
        "colorMode": "auto",
        "isDefault": false,
        "updateEnabled": true,
        "scheduledUpdateTime": "00:00",
        "updateDuration": 1,
        "defaultDimension": "2*2",
